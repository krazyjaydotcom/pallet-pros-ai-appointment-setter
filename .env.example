NODE_ENV=development
APP_BASE_URL=http://localhost:3000
APP_STATE_DIR=./work
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pallet_pros_ai
REDIS_URL=redis://localhost:6379
SESSION_SECRET=replace-with-a-long-random-secret
ENCRYPTION_KEY=replace-with-a-32-byte-base64-or-hex-key
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD_HASH=replace-with-bcrypt-hash
DEV_ADMIN_EMAIL=dev@example.com
DEV_ADMIN_PASSWORD=dev-password
OPENAI_API_KEY=replace-with-openai-key
OPENAI_MODEL=gpt-5.4-mini
OPENAI_REASONING_EFFORT=low
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
KOMMO_SUBDOMAIN=your-subdomain
KOMMO_CLIENT_ID=replace-with-kommo-client-id
KOMMO_CLIENT_SECRET=replace-with-kommo-client-secret
KOMMO_REDIRECT_URI=https://your-app.example.com/api/kommo/oauth/callback
KOMMO_ACCESS_TOKEN=
KOMMO_REFRESH_TOKEN=
OPERATING_MODE=APPROVAL_ONLY
AUTO_SEND_CONFIDENCE_THRESHOLD=0.90
MESSAGE_DEBOUNCE_SECONDS=8
MESSAGE_WINDOW_HOURS=24
TRAINING_URL=https://www.palletprosacademy.com/training
BOOKING_URL=https://www.tidycal.com/palletprosga/discovery
BUSINESS_TIMEZONE=America/New_York
